# Backend Environment Variables
NODE_ENV=production
PORT=5000

# Security (CRITICAL: Change these in production!)
JWT_SECRET=super_secure_random_string_here_change_me

# Database Configuration (PostgreSQL)
POSTGRES_USER=hantios_admin
POSTGRES_PASSWORD=supersecret123
POSTGRES_DB=hantios_prod
# DATABASE_URL is constructed automatically in docker-compose, but if running locally:
# DATABASE_URL=postgres://hantios_admin:supersecret123@localhost:5432/hantios_prod

# Google Generative AI (Gemini) - Required for AI assistant
GEMINI_API_KEY=your_gemini_api_key_here

# Allowed Origins (CORS)
ALLOWED_ORIGIN=https://your-production-domain.com
